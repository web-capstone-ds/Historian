{
  "name": "ds-historian",
  "version": "0.1.0",
  "private": true,
  "description": "DS Historian 시계열 적재 서버 (MQTT → TimescaleDB)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
